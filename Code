    <!-- Interactive Scripts -->
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            const brandLogo = document.getElementById('brand-logo');
            const navLinks = document.getElementById('nav-links');
            
            if (window.scrollY > 50) {
                navbar.classList.remove('bg-transparent', 'py-6');
                navbar.classList.add('bg-white', 'shadow-md', 'py-4');
                brandLogo.classList.remove('text-white');
                brandLogo.classList.add('text-slate');
                navLinks.classList.remove('text-white');
                navLinks.classList.add('text-slate');
            } else {
                navbar.classList.add('bg-transparent', 'py-6');
                navbar.classList.remove('bg-white', 'shadow-md', 'py-4');
                brandLogo.classList.add('text-white');
                brandLogo.classList.remove('text-slate');
                navLinks.classList.add('text-white');
                navLinks.classList.remove('text-slate');
            }
        });

        // Accordion Toggle
        function toggleAccordion(contentId, iconId) {
            const content = document.getElementById(contentId);
            const icon = document.getElementById(iconId);
            
            // Toggle active class
            if (content.classList.contains('active')) {
                content.classList.remove('active');
                icon.classList.remove('rotate-45');
                icon.classList.add('fa-plus');
                icon.classList.remove('fa-times');
            } else {
                // Close all other accordions first (optional, but good for UX)
                const allContents = document.querySelectorAll('.accordion-content');
                const allIcons = document.querySelectorAll('.fa-times');
                allContents.forEach(c => c.classList.remove('active'));
                allIcons.forEach(i => {
                    i.classList.remove('fa-times', 'rotate-45');
                    i.classList.add('fa-plus');
                });

                content.classList.add('active');
                icon.classList.remove('fa-plus');
                icon.classList.add('fa-times', 'rotate-45');
            }
        }
    </script>
